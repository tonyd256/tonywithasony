---
layout: default
---

<header class="px-6">
  {% render "nav", color: "black", class: "sm:h-8 h-6", collections: collections, page: page %}
</header>

<article class="flex items-center flex-col w-full mb-16">
  <header class="mt-6 w-full px-4 max-w-3xl">
    <a href="/writing/" class="inline-block text-blue-600 hover:text-blue-700 hover:underline font-sans font-bold tracking-widest uppercase text-xs mb-3">Writing</a>
    <h1 class="lg:text-5xl md:text-4xl text-3xl font-sans font-black leading-tight text-neutral-900">{{ title }}</h1>
    {% if subtitle %}
      <p class="mt-3 text-lg md:text-xl text-gray-500 font-sans italic">{{ subtitle }}</p>
    {% endif %}
    <p class="mt-2 text-gray-400 font-sans text-sm">{{ date | date: "%B %e, %Y" }}</p>
  </header>

  <div class="prose md:prose-lg w-full px-4 mt-8 prose-headings:font-sans prose-headings:font-bold prose-headings:leading-snug prose-headings:text-neutral-900 prose-p:leading-relaxed prose-li:leading-relaxed prose-img:rounded prose-figure:my-6 prose-figcaption:text-center prose-figcaption:text-sm prose-figcaption:mt-2 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline">
    {{ content }}
  </div>

  <div class="max-w-3xl w-full px-4 mt-12 pt-6 border-t border-gray-200 font-sans">
    <a class="text-blue-600 hover:underline" href="/writing/">&larr; All writing</a>
    {% if substack_url %}
      <a class="text-gray-400 hover:text-gray-600 ml-4" href="{{ substack_url }}" target="_blank" rel="noopener noreferrer">View original on Substack &#8599;</a>
    {% endif %}
  </div>
</article>
